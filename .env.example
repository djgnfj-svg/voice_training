# Shared environment for Docker Compose.
# Copy this file to .env and fill in real values.

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/voiceprep
DIRECT_URL=postgresql://user:password@localhost:5432/voiceprep

# Auth
NEXTAUTH_SECRET=replace-with-random-secret
NEXTAUTH_URL=http://localhost:81
AUTH_TRUST_HOST=true
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Internal service routing
BACKEND_URL=http://backend:8000

# Backend AI
OPENAI_API_KEY=
TAVILY_API_KEY=
ENVIRONMENT=development
AGENT_MODEL=gpt-4o-mini
ADMIN_EMAILS=

# Public frontend build/runtime values
NEXT_PUBLIC_ADMIN_EMAILS=
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# TTS optional overrides
TTS_MODEL=gpt-4o-mini-tts
TTS_DEFAULT_VOICE=sage
TTS_FORMAT=mp3
TTS_SPEED=2.0
