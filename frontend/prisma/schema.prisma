generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  emailVerified  DateTime?
  name           String?
  image          String?
  hashedPassword String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts           Account[]
  sessions           Session[]
  jobPostings        JobPosting[]
  interviewSessions  InterviewSession[]
  resumes            Resume[]
  activityLogs       ActivityLog[]
  answerAssistSessions AnswerAssistSession[]

  @@map("users")
}

model Resume {
  id         String   @id @default(uuid())
  userId     String
  name       String
  fileUrl    String?
  parsedData Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  interviewSessions InterviewSession[]
  activityLogs      ActivityLog[]
  answerAssistSessions AnswerAssistSession[]

  @@index([userId])
  @@map("resumes")
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model JobPosting {
  id              String   @id @default(uuid())
  userId          String
  rawText         String   @db.Text
  rawTextHash     String?  @db.VarChar(64) // sha256 of rawText — per-user cache key
  parsedData      Json?    // { company, position, requirements, preferred, techStack, duties, teamInfo }
  companyAnalysis Json?    // { interviewStyle, culture, pastQuestions }
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  interviewSessions InterviewSession[]

  @@index([userId])
  @@index([userId, rawTextHash])
  @@map("job_postings")
}

model InterviewSession {
  id              String          @id @default(uuid())
  userId          String
  jobPostingId    String?
  resumeId        String?
  type            InterviewType   @default(TECHNICAL)
  categories      String[]
  difficulty      Difficulty      @default(INTERMEDIATE)
  status          SessionStatus   @default(IN_PROGRESS)
  overallScore    Float?
  matchingScore   Float?          // Job posting matching percentage
  gapAnalysis     Json?           // { missingSkills, weakAreas, suggestions }
  reportData      Json?           // Full report data
  durationSeconds Int?
  totalQuestions  Int             @default(5)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  textMode       Boolean         @default(false)

  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobPosting JobPosting?       @relation(fields: [jobPostingId], references: [id])
  resume     Resume?           @relation(fields: [resumeId], references: [id], onDelete: SetNull)
  answers    InterviewAnswer[]

  @@index([userId])
  @@index([resumeId])
  @@index([jobPostingId])
  @@map("interview_sessions")
}

model InterviewAnswer {
  id               String   @id @default(uuid())
  sessionId        String
  questionIndex    Int
  questionText     String   @db.Text
  questionSource   String   @default("general") // job_posting, resume_based, general
  category         String?
  difficulty       String?
  answerTranscript String?  @db.Text
  audioUrl         String?
  scores           Json?    // { accuracy, depth, clarity, completeness, practicality }
  overallScore     Float?
  briefFeedback    String?  @db.Text
  detailedFeedback String?  @db.Text
  modelAnswer      String?  @db.Text
  followUpQuestion String?  @db.Text
  responseTimeSec  Int?
  createdAt        DateTime @default(now())

  session InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, questionIndex])
  @@map("interview_answers")
}

model QuestionBank {
  id          String     @id @default(uuid())
  category    String
  subcategory String
  difficulty  Difficulty
  questionText String   @db.Text
  keyPoints   String[]
  createdAt   DateTime  @default(now())

  @@index([category, subcategory, difficulty])
  @@map("question_bank")
}

enum InterviewType {
  TECHNICAL
  BEHAVIORAL
  MIXED
}

enum Difficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum SessionStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

model ActivityLog {
  id        String       @id @default(uuid())
  userId    String
  type      ActivityType
  resumeId  String?
  metadata  Json?
  createdAt DateTime     @default(now())

  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume Resume?        @relation(fields: [resumeId], references: [id], onDelete: SetNull)
  items  ActivityItem[]

  @@index([userId, createdAt])
  @@map("activity_logs")
}

model ActivityItem {
  id            String @id @default(uuid())
  activityLogId String
  index         Int
  question      String @db.Text
  answer        String @db.Text
  extra         Json?

  activityLog ActivityLog @relation(fields: [activityLogId], references: [id], onDelete: Cascade)

  @@index([activityLogId])
  @@map("activity_items")
}

enum ActivityType {
  MODEL_ANSWER
  NIGHTLY_STUDY
  LEARNING_SESSION
  LEARNING_AGENT
}

model AnswerAssistSession {
  id        String   @id @default(uuid())
  userId    String
  resumeId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume Resume?             @relation(fields: [resumeId], references: [id], onDelete: SetNull)
  items  AnswerAssistItem[]

  @@index([userId, createdAt])
  @@map("answer_assist_sessions")
}

model AnswerAssistItem {
  id            String   @id @default(uuid())
  sessionId     String
  questionIndex Int
  questionText  String   @db.Text
  conversation  Json     @default("[]")
  finalAnswer   String?  @db.Text
  isCompleted   Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  session AnswerAssistSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, questionIndex])
  @@map("answer_assist_items")
}

