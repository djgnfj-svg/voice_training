generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  emailVerified  DateTime?
  name           String?
  image          String?
  hashedPassword String?
  creditBalance  Int       @default(0)
  freeTrialUsed  Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts           Account[]
  sessions           Session[]
  jobPostings        JobPosting[]
  interviewSessions  InterviewSession[]
  resumes            Resume[]
  creditTransactions CreditTransaction[]
  paymentOrders      PaymentOrder[]
  activityLogs       ActivityLog[]
  couponUsages       CouponUsage[]
  answerAssistSessions AnswerAssistSession[]
  userKnowledge      UserKnowledge[]
  dailyProgress      DailyProgress[]
  learningAgentSessions LearningAgentSession[]

  @@map("users")
}

model Resume {
  id         String   @id @default(uuid())
  userId     String
  name       String
  fileUrl    String?
  parsedData Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  interviewSessions InterviewSession[]
  activityLogs      ActivityLog[]
  answerAssistSessions AnswerAssistSession[]

  @@index([userId])
  @@map("resumes")
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model JobPosting {
  id              String   @id @default(uuid())
  userId          String
  rawText         String   @db.Text
  parsedData      Json?    // { company, position, requirements, preferred, techStack, duties, teamInfo }
  companyAnalysis Json?    // { interviewStyle, culture, pastQuestions }
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  interviewSessions InterviewSession[]

  @@index([userId])
  @@map("job_postings")
}

model InterviewSession {
  id              String          @id @default(uuid())
  userId          String
  jobPostingId    String?
  resumeId        String?
  type            InterviewType   @default(TECHNICAL)
  categories      String[]
  difficulty      Difficulty      @default(INTERMEDIATE)
  status          SessionStatus   @default(IN_PROGRESS)
  overallScore    Float?
  matchingScore   Float?          // Job posting matching percentage
  gapAnalysis     Json?           // { missingSkills, weakAreas, suggestions }
  reportData      Json?           // Full report data
  durationSeconds Int?
  totalQuestions  Int             @default(5)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  creditDeducted Boolean         @default(false)
  textMode       Boolean         @default(false)

  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobPosting JobPosting?       @relation(fields: [jobPostingId], references: [id])
  resume     Resume?           @relation(fields: [resumeId], references: [id], onDelete: SetNull)
  answers    InterviewAnswer[]

  @@index([userId])
  @@index([resumeId])
  @@index([jobPostingId])
  @@map("interview_sessions")
}

model InterviewAnswer {
  id               String   @id @default(uuid())
  sessionId        String
  questionIndex    Int
  questionText     String   @db.Text
  questionSource   String   @default("general") // job_posting, resume_based, general
  category         String?
  difficulty       String?
  answerTranscript String?  @db.Text
  audioUrl         String?
  scores           Json?    // { accuracy, depth, clarity, completeness, practicality }
  overallScore     Float?
  briefFeedback    String?  @db.Text
  detailedFeedback String?  @db.Text
  modelAnswer      String?  @db.Text
  followUpQuestion String?  @db.Text
  responseTimeSec  Int?
  createdAt        DateTime @default(now())

  session InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, questionIndex])
  @@map("interview_answers")
}

model QuestionBank {
  id          String     @id @default(uuid())
  category    String
  subcategory String
  difficulty  Difficulty
  questionText String   @db.Text
  keyPoints   String[]
  createdAt   DateTime  @default(now())

  @@index([category, subcategory, difficulty])
  @@map("question_bank")
}

enum InterviewType {
  TECHNICAL
  BEHAVIORAL
  MIXED
}

enum Difficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum SessionStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

model CreditTransaction {
  id          String       @id @default(uuid())
  userId      String
  amount      Int
  balance     Int
  type        CreditTxType
  description String?
  referenceId String?
  createdAt   DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("credit_transactions")
}

enum CreditTxType {
  FREE_TRIAL
  ADMIN_GRANT
  PURCHASE
  SESSION_DEBIT
  FEATURE_DEBIT
  REFUND
  COUPON
  LEARNING_DEBIT
}

model PaymentOrder {
  id         String        @id @default(uuid())
  userId     String
  orderId    String        @unique
  orderName  String
  amount     Int
  credits    Int
  status     PaymentStatus @default(PENDING)
  paymentKey String?
  method     String?
  approvedAt DateTime?
  failReason String?
  raw        Json?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("payment_orders")
}

enum PaymentStatus {
  PENDING
  DONE
  FAILED
  CANCELED
}

model ActivityLog {
  id        String       @id @default(uuid())
  userId    String
  type      ActivityType
  resumeId  String?
  metadata  Json?
  createdAt DateTime     @default(now())

  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume Resume?        @relation(fields: [resumeId], references: [id], onDelete: SetNull)
  items  ActivityItem[]

  @@index([userId, createdAt])
  @@map("activity_logs")
}

model ActivityItem {
  id            String @id @default(uuid())
  activityLogId String
  index         Int
  question      String @db.Text
  answer        String @db.Text
  extra         Json?

  activityLog ActivityLog @relation(fields: [activityLogId], references: [id], onDelete: Cascade)

  @@index([activityLogId])
  @@map("activity_items")
}

enum ActivityType {
  MODEL_ANSWER
  NIGHTLY_STUDY
  LEARNING_SESSION
  LEARNING_AGENT
}

model Coupon {
  id          String        @id @default(uuid())
  code        String        @unique
  credits     Int
  maxUses     Int?
  usedCount   Int           @default(0)
  isActive    Boolean       @default(true)
  expiresAt   DateTime?
  description String?
  createdAt   DateTime      @default(now())
  usages      CouponUsage[]

  @@map("coupons")
}

model CouponUsage {
  id        String   @id @default(uuid())
  couponId  String
  userId    String
  createdAt DateTime @default(now())

  coupon Coupon @relation(fields: [couponId], references: [id])
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([couponId, userId])
  @@map("coupon_usages")
}

model AnswerAssistSession {
  id        String   @id @default(uuid())
  userId    String
  resumeId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume Resume?             @relation(fields: [resumeId], references: [id], onDelete: SetNull)
  items  AnswerAssistItem[]

  @@index([userId, createdAt])
  @@map("answer_assist_sessions")
}

model AnswerAssistItem {
  id            String   @id @default(uuid())
  sessionId     String
  questionIndex Int
  questionText  String   @db.Text
  conversation  Json     @default("[]")
  finalAnswer   String?  @db.Text
  isCompleted   Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  session AnswerAssistSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, questionIndex])
  @@map("answer_assist_items")
}

// ========================
// Learning System Models
// ========================

model Subject {
  id          String   @id @default(uuid())
  slug        String   @unique
  name        String
  nameEn      String?
  description String?  @db.Text
  icon        String?
  isSystem    Boolean  @default(false)
  createdBy   String?
  parentId    String?
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent   Subject?  @relation("SubjectHierarchy", fields: [parentId], references: [id])
  children Subject[] @relation("SubjectHierarchy")
  topics   Topic[]

  @@index([isSystem])
  @@index([createdBy])
  @@map("subjects")
}

model Topic {
  id          String     @id @default(uuid())
  subjectId   String
  name        String
  description String?    @db.Text
  difficulty  Difficulty @default(INTERMEDIATE)
  keyPoints   String[]
  metadata    Json?
  createdAt   DateTime   @default(now())

  subject       Subject         @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  userKnowledge UserKnowledge[]

  @@index([subjectId])
  @@map("topics")
}

model UserKnowledge {
  id            String    @id @default(uuid())
  userId        String
  topicId       String
  proficiency   Int       @default(0)
  successCount  Int       @default(0)
  failureCount  Int       @default(0)
  streakCount   Int       @default(0)
  lastPracticed DateTime?
  nextReviewAt  DateTime?
  metadata      Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic Topic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([userId, topicId])
  @@index([userId, nextReviewAt])
  @@map("user_knowledge")
}

model DailyProgress {
  id              String   @id @default(uuid())
  userId          String
  date            DateTime @db.Date
  totalSessions   Int      @default(0)
  totalQuestions   Int      @default(0)
  totalCorrect    Int      @default(0)
  totalMinutes    Int      @default(0)
  topicsStudied   String[]
  subjectsStudied String[]
  streakDay       Int      @default(1)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
  @@map("daily_progress")
}

// ========================
// Learning Agent Models
// ========================

model LearningAgentSession {
  id             String   @id @default(uuid())
  userId         String
  topic          String?
  status         String   @default("active")
  llmCallCount   Int      @default(0)
  creditDeducted Boolean  @default(false)
  isFreeSession  Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user     User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages LearningAgentMessage[]

  @@index([userId])
  @@index([userId, createdAt])
  @@map("learning_agent_sessions")
}

model LearningAgentMessage {
  id           String   @id @default(uuid())
  sessionId    String
  messageIndex Int
  role         String
  content      String   @db.Text
  phase        String?
  assessment   Json?
  createdAt    DateTime @default(now())

  session LearningAgentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, messageIndex])
  @@index([sessionId])
  @@map("learning_agent_messages")
}
